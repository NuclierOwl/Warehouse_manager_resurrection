<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Inventori_Manager.ViewModels"
        xmlns:dg="https://github.com/avaloniaui/datagrid"
        xmlns:dao="clr-namespace:Proba_Sklada.Hardik.Dao"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="Inventori_Manager.OperatorWindow"
        x:DataType="vm:InventoryViewModel"
        Title="Warehouse Management System"
        FontFamily="Segoe UI, Roboto, sans-serif"
        Background="#FF0A0A0F"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="600">

    <Window.Resources>
    <!-- Цветовая схема -->
    <Color x:Key="PrimaryBackgroundColor">#FF0A0A0F</Color>
    <Color x:Key="SecondaryBackgroundColor">#FF15151E</Color>
    <Color x:Key="TertiaryBackgroundColor">#FF1E1E2A</Color>
    <Color x:Key="CardBackgroundColor">#FF1C1C24</Color>
    <Color x:Key="BorderColor">#FF2A2A38</Color>
    <Color x:Key="AccentColor">#FF00B4D8</Color>
    <Color x:Key="AccentHoverColor">#FF48CAE4</Color>
    <Color x:Key="SuccessColor">#FF00CC88</Color>
    <Color x:Key="WarningColor">#FFFFAA00</Color>
    <Color x:Key="ErrorColor">#FFFF5555</Color>
    <Color x:Key="PrimaryTextColor">#FFF0F0F0</Color>
    <Color x:Key="SecondaryTextColor">#FFA0A0B0</Color>
    <Color x:Key="DisabledTextColor">#FF606070</Color>
    <Color x:Key="ButtonPrimaryColor">#FF00B4D8</Color>
    <Color x:Key="ButtonSecondaryColor">#FF2C2C38</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="{StaticResource PrimaryBackgroundColor}"/>
    <SolidColorBrush x:Key="SecondaryBackground" Color="{StaticResource SecondaryBackgroundColor}"/>
    <SolidColorBrush x:Key="TertiaryBackground" Color="{StaticResource TertiaryBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}"/>
    <SolidColorBrush x:Key="ButtonPrimaryBackground" Color="{StaticResource ButtonPrimaryColor}"/>
    <SolidColorBrush x:Key="ButtonSecondaryBackground" Color="{StaticResource ButtonSecondaryColor}"/>
</Window.Resources>

    <Window.Styles>
    <!-- Стиль для текстовых полей -->
    <Style Selector="TextBox, ComboBox, DatePicker, NumericUpDown">
        <Setter Property="Background" Value="{StaticResource TertiaryBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource ButtonSecondaryBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource TertiaryBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource BorderColor}"/>
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{StaticResource ButtonPrimaryBackground}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource ButtonPrimaryBackground}"/>
    </Style>
    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style Selector="TextBlock.input-label">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,0,5,0"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="RowBackground" Value="{StaticResource CardBackground}"/>
        <!-- AlternatingRowBackground удалено, т.к. не поддерживается -->
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource TertiaryBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    <Style Selector="DataGridRow:pointerover">
        <Setter Property="Background" Value="{StaticResource TertiaryBackground}"/>
    </Style>
    <Style Selector="DataGridCell">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
</Window.Styles>



    <DockPanel>
        <!-- Верхний заголовок -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SecondaryBackground}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="📦" FontSize="24" VerticalAlignment="Center"/>
                <TextBlock Text="Warehouse Management System" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="| Операторский терминал" FontSize="14" 
                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="20,20,20,0">
            <TabControl>
                <!-- ========== Вкладка "Приход товаров" ========== -->
                <TabItem Header="📥 Приход товаров">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <!-- Карточка новой поставки -->
                            <Border Classes="card">
                                <StackPanel Spacing="16">
                                    <TextBlock Classes="section-header" Text="➕ Новая поставка"/>

                                    <!-- Строка: номер накладной и дата -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Номер накладной:" Grid.Column="0"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewInvoiceNumber}" Watermark="Введите номер"/>
                                        <TextBlock Classes="input-label" Text="Дата:" Grid.Column="2"/>
                                        <DatePicker Grid.Column="3" SelectedDate="{Binding NewInvoiceDate}"/>
                                    </Grid>

                                    <!-- Строка: поставщик, товар, количество -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Поставщик:" Grid.Column="0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Suppliers}" 
                                                  DisplayMemberBinding="{Binding name}" 
                                                  SelectedItem="{Binding SelectedSupplier}"/>
                                        <TextBlock Classes="input-label" Text="Товар:" Grid.Column="2"/>
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding Products}" 
                                                  DisplayMemberBinding="{Binding name}" 
                                                  SelectedItem="{Binding SelectedProduct}"/>
                                        <TextBlock Classes="input-label" Text="Количество:" Grid.Column="4"/>
                                        <NumericUpDown Grid.Column="5" Value="{Binding Quantity}" 
                                                       Minimum="0" FormatString="F0" ShowButtonSpinner="True"/>
                                    </Grid>

                                    <!-- Строка: место хранения и партия -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Место хранения:" Grid.Column="0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding StorageLocations}" 
                                                  DisplayMemberBinding="{Binding location_code}" 
                                                  SelectedItem="{Binding SelectedLocation}"/>
                                        <TextBlock Classes="input-label" Text="Партия / серийный номер:" Grid.Column="2"/>
                                        <TextBox Grid.Column="3" Text="{Binding BatchNumber}" Watermark="Опционально"/>
                                    </Grid>

                                    <Button Classes="accent" Content="➕ Добавить товар в накладную" 
                                            Command="{Binding AddToInvoiceCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Таблица товаров в накладной -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="section-header" Text="📋 Текущая накладная"/>
                                    <DataGrid ItemsSource="{Binding CurrentInvoiceItems}" 
                                              AutoGenerateColumns="False" MinHeight="200">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="100"/>
                                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="120"/>
                                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="120"/>
                                            <DataGridTextColumn Header="Партия" Binding="{Binding BatchNumber}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                        <Button Classes="accent" Content="💾 Сохранить накладную" Command="{Binding SaveInvoiceCommand}"/>
                                        <Button Content="🗑 Очистить" Command="{Binding ClearInvoiceCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ========== Вкладка "Инвентаризация" ========== -->
                <TabItem Header="🔍 Инвентаризация">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <Border Classes="card">
                                <StackPanel Spacing="16">
                                    <TextBlock Classes="section-header" Text="📊 Сверка фактических остатков"/>

                                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Товар:" Grid.Column="0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Products}" 
                                                  DisplayMemberBinding="{Binding name}" 
                                                  SelectedItem="{Binding SelectedProductInv}"/>
                                        <TextBlock Classes="input-label" Text="Место хранения:" Grid.Column="2"/>
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding StorageLocations}" 
                                                  DisplayMemberBinding="{Binding location_code}" 
                                                  SelectedItem="{Binding SelectedLocationInv}"/>
                                        <TextBlock Classes="input-label" Text="Фактическое кол-во:" Grid.Column="4"/>
                                        <NumericUpDown Grid.Column="5" Value="{Binding ActualQuantity}" 
                                                       Minimum="0" FormatString="F0" ShowButtonSpinner="True"/>
                                    </Grid>

                                    <Button Classes="accent" Content="📝 Зафиксировать расхождение" 
                                            Command="{Binding RecordDiscrepancyCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="section-header" Text="⚠️ Журнал расхождений"/>
                                    <DataGrid ItemsSource="{Binding Discrepancies}" AutoGenerateColumns="False" MinHeight="250">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="120"/>
                                            <DataGridTextColumn Header="Ожидаемое" Binding="{Binding ExpectedQuantity}" Width="100"/>
                                            <DataGridTextColumn Header="Фактическое" Binding="{Binding ActualQuantity}" Width="100"/>
                                            <DataGridTextColumn Header="Расхождение" Binding="{Binding Discrepancy}" Width="100"/>
                                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ========== Вкладка "Списание товаров" ========== -->
                <TabItem Header="🗑 Списание товаров">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <Border Classes="card">
                                <StackPanel Spacing="16">
                                    <TextBlock Classes="section-header" Text="📄 Расходная накладная"/>

                                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Номер накладной:" Grid.Column="0"/>
                                        <TextBox Grid.Column="1" Text="{Binding ExpenseInvoiceNumber}" Watermark="Введите номер"/>
                                        <TextBlock Classes="input-label" Text="Дата:" Grid.Column="2"/>
                                        <DatePicker Grid.Column="3" SelectedDate="{Binding ExpenseInvoiceDate}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Покупатель:" Grid.Column="0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Customers}" 
                                                  DisplayMemberBinding="{Binding name}" 
                                                  SelectedItem="{Binding SelectedCustomer}"/>
                                        <TextBlock Classes="input-label" Text="Товар:" Grid.Column="2"/>
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding Products}" 
                                                  DisplayMemberBinding="{Binding name}" 
                                                  SelectedItem="{Binding SelectedProductExp}"/>
                                        <TextBlock Classes="input-label" Text="Количество:" Grid.Column="4"/>
                                        <NumericUpDown Grid.Column="5" Value="{Binding ExpenseQuantity}" 
                                                       Minimum="0" FormatString="F0" ShowButtonSpinner="True"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                                        <TextBlock Classes="input-label" Text="Место хранения:" Grid.Column="0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding StorageLocations}" 
                                                  DisplayMemberBinding="{Binding location_code}" 
                                                  SelectedItem="{Binding SelectedLocationExp}"/>
                                        <TextBlock Classes="input-label" Text="Цена за единицу:" Grid.Column="2"/>
                                        <NumericUpDown Grid.Column="3" Value="{Binding ExpenseUnitPrice}" 
                                                       Minimum="0" FormatString="F2" ShowButtonSpinner="True"/>
                                    </Grid>

                                    <Button Classes="accent" Content="➕ Добавить в накладную" 
                                            Command="{Binding AddToExpenseCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="section-header" Text="📋 Товары в расходной накладной"/>
                                    <DataGrid ItemsSource="{Binding CurrentExpenseItems}" AutoGenerateColumns="False" MinHeight="200">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="100"/>
                                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="120"/>
                                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                        <Button Classes="accent" Content="💾 Сохранить накладную" Command="{Binding SaveExpenseCommand}"/>
                                        <Button Content="🗑 Очистить" Command="{Binding ClearExpenseCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ========== Вкладка "Позиции" ========== -->
                <TabItem Header="📍 Позиции">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="section-header" Text="🗄 Складские позиции"/>
                                    <TextBlock Text="Наведите курсор на позицию, чтобы увидеть, что и сколько хранится"
                                               Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" 
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <DataGrid ItemsSource="{Binding LocationStocks}" AutoGenerateColumns="False"
                                              IsReadOnly="True" MinHeight="300">
                                        <DataGrid.Styles>
                                            <Style Selector="DataGridRow" x:DataType="vm:InventoryViewModel+LocationStockModel">
                                                <Setter Property="ToolTip.Tip" Value="{Binding TooltipText}"/>
                                            </Style>
                                        </DataGrid.Styles>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Позиция (стеллаж / ячейка)" Binding="{Binding LocationCode}" Width="*"/>
                                            <DataGridTextColumn Header="Общее количество, шт." Binding="{Binding TotalQuantity}" Width="150"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- Нижняя статусная строка -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SecondaryBackground}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="✅ Система готова к работе" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding CurrentDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" 
                           Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
            </Grid>
        </Border>
    </DockPanel>
</Window>