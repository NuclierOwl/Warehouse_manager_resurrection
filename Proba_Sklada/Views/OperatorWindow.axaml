<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Inventori_Manager.ViewModels"
        xmlns:dg="https://github.com/avaloniaui/datagrid"
        xmlns:dao="clr-namespace:Proba_Sklada.Hardik.Dao"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Inventori_Manager.OperatorWindow"
        x:DataType="vm:InventoryViewModel"
        Title="Управление складом">

    <Grid RowDefinitions="Auto,*" Margin="{DynamicResource DashPagePadding}">
        <Border Grid.Row="0" Classes="Card" Padding="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconBox}"
                              Width="18"
                              Height="18"
                              Foreground="{DynamicResource DashAccentBrush}" />
                    <TextBlock Classes="H2" Name="IntroBox" />
                </StackPanel>

                <Button Grid.Column="1"
                        Name="ExitButton"
                        Content="Выйти"
                        Click="ExitButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="Card" Margin="0,14,0,0" Padding="12">
            <TabControl>
            <!-- Вкладка "Приход товаров" -->
            <TabItem Header="Прием товаров">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="5">
                    <TextBlock Grid.Row="0" Text="Новая поставка" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Номер накладной:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Column="1" Text="{Binding NewInvoiceNumber}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Дата:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker Grid.Column="3" SelectedDate="{Binding NewInvoiceDate}" Margin="5"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Поставщик:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Suppliers}" 
                                  DisplayMemberBinding="{Binding name}" 
                                  SelectedItem="{Binding SelectedSupplier}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Товар:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding Products}" 
                                  DisplayMemberBinding="{Binding name}" 
                                  SelectedItem="{Binding SelectedProduct}" Margin="5"/>
                        <TextBlock Grid.Column="4" Text="Количество:" VerticalAlignment="Center" Margin="5"/>
                        <NumericUpDown Grid.Column="5" Value="{Binding Quantity}" 
                                       Minimum="0" FormatString="F0" Margin="5"/>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Место хранения:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding StorageLocations}" 
                                  DisplayMemberBinding="{Binding location_code}" 
                                  SelectedItem="{Binding SelectedLocation}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Партия/серийный номер:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Column="3" Text="{Binding BatchNumber}" Margin="5"/>
                    </Grid>

                    <Button Grid.Row="4" Content="Добавить товар в накладную" 
                            Command="{Binding AddToInvoiceCommand}" 
                            HorizontalAlignment="Left" Margin="5,10"/>

                    <DataGrid Grid.Row="5" ItemsSource="{Binding CurrentInvoiceItems}" Margin="5"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="Auto"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="Auto"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="Auto"/>
                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="Auto"/>
                            <DataGridTextColumn Header="Партия" Binding="{Binding BatchNumber}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="Сохранить накладную" Command="{Binding SaveInvoiceCommand}" Margin="5,0"/>
                        <Button Content="Очистить" Command="{Binding ClearInvoiceCommand}" Margin="5,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка "Инвентаризация" -->
            <TabItem Header="Инвентаризация">
                <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="5">
                    <TextBlock Grid.Row="0" Text="Сверка фактических остатков" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Товар:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Products}" 
                                  DisplayMemberBinding="{Binding name}" 
                                  SelectedItem="{Binding SelectedProductInv}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Место хранения:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding StorageLocations}" 
                                  DisplayMemberBinding="{Binding location_code}" 
                                  SelectedItem="{Binding SelectedLocationInv}" Margin="5"/>
                        <TextBlock Grid.Column="4" Text="Фактическое кол-во:" VerticalAlignment="Center" Margin="5"/>
                        <NumericUpDown Grid.Column="5" Value="{Binding ActualQuantity}" 
                                       Minimum="0" FormatString="F0" Margin="5"/>
                    </Grid>

                    <Button Grid.Row="2" Content="Зафиксировать расхождение" 
                            Command="{Binding RecordDiscrepancyCommand}"
                            HorizontalAlignment="Left" Margin="5,10"/>

                    <DataGrid Grid.Row="3" ItemsSource="{Binding Discrepancies}" Margin="5"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="Auto"/>
                            <DataGridTextColumn Header="Ожидаемое" Binding="{Binding ExpectedQuantity}" Width="Auto"/>
                            <DataGridTextColumn Header="Фактическое" Binding="{Binding ActualQuantity}" Width="Auto"/>
                            <DataGridTextColumn Header="Расхождение" Binding="{Binding Discrepancy}" Width="Auto"/>
                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка "Списание" -->
            <TabItem Header="Списание товаров">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="5">
                    <TextBlock Grid.Row="0" Text="Расходная накладная" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Номер накладной:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Column="1" Text="{Binding ExpenseInvoiceNumber}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Дата:" VerticalAlignment="Center" Margin="5"/>
                        <DatePicker Grid.Column="3" SelectedDate="{Binding ExpenseInvoiceDate}" Margin="5"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Покупатель:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Customers}" 
                                  DisplayMemberBinding="{Binding name}" 
                                  SelectedItem="{Binding SelectedCustomer}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Товар:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding Products}" 
                                  DisplayMemberBinding="{Binding name}" SelectionChanged="SelectionProd"
                                  SelectedItem="{Binding SelectedProductExp}" Margin="5"/>
                        <TextBlock Grid.Column="4" Text="Количество:" VerticalAlignment="Center" Margin="5"/>
                        <NumericUpDown Grid.Column="5" Value="{Binding ExpenseQuantity}" 
                                       Minimum="0" FormatString="F0" Margin="5"/>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,*" Margin="0,5">
                        <TextBlock Text="Место хранения:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding StorageLocations}" 
                                  DisplayMemberBinding="{Binding location_code}" 
                                  SelectedItem="{Binding SelectedLocationExp}" Margin="5"/>
                        <TextBlock Grid.Column="2" Text="Цена за единицу:" VerticalAlignment="Center" Margin="5"/>
                        <NumericUpDown Grid.Column="3" Value="{Binding ExpenseUnitPrice}" 
                                       Minimum="0" FormatString="F2" Margin="5" Name="CenikBox"/>
                    </Grid>

                    <Button Grid.Row="4" Content="Добавить в накладную" 
                            Command="{Binding AddToExpenseCommand}"
                            HorizontalAlignment="Left" Margin="5,10"/>

                    <DataGrid Grid.Row="5" ItemsSource="{Binding CurrentExpenseItems}" Margin="5"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="Auto"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="Auto"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="Auto"/>
                            <DataGridTextColumn Header="Место" Binding="{Binding LocationCode}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="Сохранить накладную" Command="{Binding SaveExpenseCommand}" Margin="5,0"/>
                        <Button Content="Очистить" Command="{Binding ClearExpenseCommand}" Margin="5,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

 
            <TabItem Header="Позиции">
    <Grid RowDefinitions="Auto,Auto,*" Margin="5">
        <TextBlock Grid.Row="0" Text="Текущие остатки на складе" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="{DynamicResource DashSurface2Brush}" 
                CornerRadius="5" Padding="8" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto" RowDefinitions="Auto,Auto"
                  ColumnSpacing="8" RowSpacing="5">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Товар:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                          ItemsSource="{Binding Products}" 
                          DisplayMemberBinding="{Binding name}" 
                          Name="ProductsBox"
                          MinWidth="150"
                          SelectionChanged="Obnovka_SelectionChanged"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Место хранения:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="3" 
                          ItemsSource="{Binding StorageLocations}" 
                          DisplayMemberBinding="{Binding location_code}" 
                          Name="LocationBox"
                          MinWidth="150"
                          SelectionChanged="Obnovka_SelectionChanged"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Партия / серийный номер:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="5" 
                         Name="BatchBox" MinWidth="150"
                         TextChanged="Obnovka_TextChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Кол-во > 0:" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="1" Grid.Column="1" Name="PositiveBox"
                          VerticalAlignment="Center" Margin="0,0,0,0"
                          Click="Obnovka_CheckBox_Changed"/>

                <Button Grid.Row="1" Grid.Column="6" Content="Сбросить фильтр" 
                        Click="ResetFilter_Click"
                        HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="2" Name="InventoryBox" Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="dao:inventory">
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding product.name}" MinWidth="150" />
                            <TextBlock Text="{Binding location.location_code}" MinWidth="100" />
                            <TextBlock Text="{Binding kolichestvo}" MinWidth="60" />
                            <TextBlock Text="{Binding batch_number}" MinWidth="100" />
                            <TextBlock Text="{Binding serial_number}" MinWidth="120" />
                            <TextBlock Text="{Binding production_date, StringFormat='yyyy-MM-dd'}" MinWidth="100" />
                            <TextBlock Text="{Binding spisanie_date, StringFormat='yyyy-MM-dd'}" MinWidth="100" />
                            <TextBlock Text="{Binding last_updated, StringFormat='yyyy-MM-dd HH:mm'}" MinWidth="140" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>