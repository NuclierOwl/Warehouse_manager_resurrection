<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:vm="clr-namespace:Inventori_Manager.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Inventori_Manager.MenegerWindow"
        x:DataType="vm:MenegerViewModel"
        Title="ћенеджмент"
        FontFamily="Segoe UI"
        Background="#FF0A0A0F">
<StackPanel>
      <DockPanel>
          <ComboBox Name="ComboFilter" SelectionChanged="SelectionChanged">
              <ComboBoxItem>¬се</ComboBoxItem>
                <ComboBoxItem>ѕо убыванию</ComboBoxItem>
                <ComboBoxItem>ѕо возрастанию</ComboBoxItem>
          </ComboBox>
          <Button Name="ExitButton" 
            Content="¬ыйти" 
            Click="ExitButton_Click"/>

          <TextBox Name="SerchBox" Watermark="ѕоиск...ШШШШШ" TextChanged="TextChanged"/>
      </DockPanel>
  
      <TabControl>
          <TabItem Header="ќтчетность">

          </TabItem>
          <TabItem Header="—татистика">
              <Grid RowDefinitions="Auto,*" Margin="12">
                  <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                      <StackPanel>
                          <TextBlock Text="ШШШШШШ Ш" Margin="0,0,0,4"/>
                          <DatePicker SelectedDate="{Binding StartDate}" Width="160"/>
                      </StackPanel>
                      <StackPanel>
                          <TextBlock Text="ШШ" Margin="0,0,0,4"/>
                          <DatePicker SelectedDate="{Binding EndDate}" Width="160"/>
                      </StackPanel>
                      <StackPanel>
                          <TextBlock Text="ШШШШШШШШШШШ" Margin="0,0,0,4"/>
                          <ComboBox ItemsSource="{Binding GroupingOptions}"
                                    SelectedItem="{Binding SelectedGrouping}"
                                    Width="160"/>
                      </StackPanel>
                  </StackPanel>

                  <Border Grid.Row="1" Margin="0,12,0,0" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
                      <Grid RowDefinitions="Auto,*" Margin="12">
                          <TextBlock Grid.Row="0" Text="ШШШШШШШШШ / ШШШШШШШШШ" FontWeight="SemiBold" Margin="0,0,0,8"/>
                          <lvc:CartesianChart Grid.Row="1"
                                             Series="{Binding MovementSeries}"
                                             XAxes="{Binding XAxes}"
                                             YAxes="{Binding YAxes}"/>
                      </Grid>
                  </Border>
              </Grid>
          </TabItem>
      </TabControl>
  </StackPanel>
</Window>
