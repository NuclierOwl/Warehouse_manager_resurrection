<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:vm="clr-namespace:Inventori_Manager.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Inventori_Manager.MenegerWindow"
        x:DataType="vm:MenegerViewModel"
        Title="Менеджер склада">
  <Grid RowDefinitions="Auto,*" Margin="{DynamicResource DashPagePadding}">
      <Border Grid.Row="0" Classes="Card" Padding="14">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource IconBox}"
                            Width="18"
                            Height="18"
                            Foreground="{DynamicResource DashAccentBrush}" />
                  <TextBlock Classes="H2" Text="Менеджер склада" />
              </StackPanel>

              <DockPanel Grid.Column="1" LastChildFill="True">
                  <ComboBox Name="ComboFilter" Width="170" Margin="0,0,10,0" SelectionChanged="SelectionChanged">
                      <ComboBoxItem>Все</ComboBoxItem>
                      <ComboBoxItem>По убыванию</ComboBoxItem>
                      <ComboBoxItem>По возрастанию</ComboBoxItem>
                  </ComboBox>
                  <TextBox Name="SerchBox" Watermark="Поиск..." TextChanged="TextChanged"/>
              </DockPanel>

              <Button Grid.Column="2"
                      Name="ExitButton"
                      Content="Выйти"
                      Click="ExitButton_Click"/>
          </Grid>
      </Border>

      <Border Grid.Row="1" Classes="Card" Margin="0,14,0,0" Padding="12">
      <TabControl>

         <!--

          <TabItem Header="Статистика">
          </TabItem>
          <TabItem Header="Приход товаров">
          </TabItem>

          -->

          <TabItem Header="Отчёты">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                  <Border Classes="Card" Padding="10">
                      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="8">
                          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Период:" />

                          <DatePicker Grid.Row="0" Grid.Column="1"
                                      SelectedDate="{Binding StartDate}"
                                      Width="150"/>
                          <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="—" />
                          <DatePicker Grid.Row="0" Grid.Column="3"
                                      SelectedDate="{Binding EndDate}"
                                      Width="150"/>

                          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Операции:" />
                          <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                    ItemsSource="{Binding ReportOperationOptions}"
                                    SelectedItem="{Binding SelectedReportOperation}"
                                    Width="470"/>

                          <Button Grid.Row="0" Grid.Column="5"
                                  Content="Сформировать"
                                  Command="{Binding BuildReportCommand}"
                                  IsEnabled="{Binding IsReportNotBusy}"/>
                          <Button Grid.Row="0" Grid.Column="6"
                                  Content="Сохранить в PDF"
                                  Click="ExportPdf_Click"
                                  IsEnabled="{Binding IsReportNotBusy}"/>
                      </Grid>
                  </Border>

                  <DataGrid Grid.Row="1"
                            ItemsSource="{Binding ReportRows}"
                            IsReadOnly="True"
                            AutoGenerateColumns="False"
                            GridLinesVisibility="All"
                            CanUserResizeColumns="True">
                      <DataGrid.Columns>
                          <DataGridTextColumn Header="Дата" Binding="{Binding DateTime}" Width="140"/>
                          <DataGridTextColumn Header="Операция" Binding="{Binding Operation}" Width="120"/>
                          <DataGridTextColumn Header="Документ" Binding="{Binding DocumentNumber}" Width="130"/>
                          <DataGridTextColumn Header="Контрагент" Binding="{Binding Counterparty}" Width="*"/>
                          <DataGridTextColumn Header="Товар" Binding="{Binding Product}" Width="2*"/>
                          <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="90"/>
                          <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="100"/>
                          <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="110"/>
                          <DataGridTextColumn Header="Откуда" Binding="{Binding LocationFrom}" Width="120"/>
                          <DataGridTextColumn Header="Куда" Binding="{Binding LocationTo}" Width="120"/>
                      </DataGrid.Columns>
                  </DataGrid>
              </Grid>
          </TabItem>
      </TabControl>
      </Border>
  </Grid>
</Window>
