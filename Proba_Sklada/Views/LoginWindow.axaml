<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Inventori_Manager.LoginWindow"
        Title="Авторизация">
  <Grid>
    <Border Classes="Card"
            Width="420"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <StackPanel Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <PathIcon Data="{StaticResource IconBox}"
                    Width="18"
                    Height="18"
                    Foreground="{DynamicResource DashAccentBrush}" />
          <TextBlock Classes="H2" Text="Менеджер склада" />
        </StackPanel>
        
        <TextBlock Classes="Muted" Text="Введите ваш логин и пароль" />

        <StackPanel Spacing="10">
          <TextBox Watermark="Логин" x:Name="UserName"/>
          <TextBox Watermark="Пароль" x:Name="UserPass"/>
        </StackPanel>

        <Button x:Name="KnopkaWhoda"
                Classes="Primary"
                Content="Войти"
                Click="KnopkaWhoda_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
