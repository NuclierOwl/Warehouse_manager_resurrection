<Window xmlns="https://github.com/avaloniaui"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Inventori_Manager.Views.AddItemWindow"
        Width="560"
        Height="520"
        Title="Добавить новый предмет"
        WindowStartupLocation="CenterOwner">
        
    <Grid Margin="{DynamicResource DashPagePadding}">
        <Border Classes="Card">
            <StackPanel Spacing="14">
                <TextBlock Classes="H2" Text="Добавить предмет" />
                <TextBlock Classes="Muted" Text="Заполните данные и нажмите «Добавить»." />

                <Grid ColumnDefinitions="140,*" RowDefinitions="auto,auto,auto,auto" ColumnSpacing="10" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="NameTextBox" Watermark="Введите название"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Локация" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="LocationTextBox" Watermark="Введите место хранения"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Позиция" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="PositionTextBox" Watermark="Введите позицию"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Количество" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Name="QuantityTextBox" Watermark="0" Text="0"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,6,0,0">
                    <Button Content="Отмена" Click="CancelButton_Click"/>
                    <Button Classes="Primary" Content="Добавить" Click="AddButton_Click" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>